{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 30,
  "positionX": "right",
  "positionY": "top",
  "control-center-width": 380,
  "fit-to-screen": false,
  "layer": "overlay",
  "control-center-layer": "top",
  "cssPriority": "user",
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "transition-time": 200,
  "notification-window-width": 380,
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "volume",
    "backlight",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "volume": {
      "label": "Volume"
    },
    "backlight": {
      "label": "Brightness"
    },
    "mpris": {
      "image-size": 64,
      "image-radius": 8,
      "autohide": true
    }
  }
}
