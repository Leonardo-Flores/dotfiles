#!/bin/bash
# Wi-Fi menu using wofi — scan, connect, disconnect

wifi_status=$(nmcli radio wifi)

if [ "$wifi_status" = "disabled" ]; then
    chosen=$(printf "  Turn Wi-Fi On\n" | wofi --dmenu --width 300 --height 55 --cache-file /dev/null --prompt "Wi-Fi Off")
    [[ "$chosen" == *"Turn Wi-Fi On"* ]] && nmcli radio wifi on
    exit 0
fi

# Get current connection
current_ssid=$(nmcli -t -f active,ssid dev wifi | grep "^yes:" | cut -d: -f2)

# Scan in background and list networks
nmcli dev wifi rescan 2>/dev/null
sleep 1

entries=()
ssids=()

while IFS='|' read -r ssid signal security active; do
    [ -z "$ssid" ] && continue

    # Signal icon
    if [ "$signal" -ge 75 ]; then
        icon="󰤨"
    elif [ "$signal" -ge 50 ]; then
        icon="󰤥"
    elif [ "$signal" -ge 25 ]; then
        icon="󰤢"
    else
        icon="󰤟"
    fi

    # Lock icon for secured networks
    lock=""
    [[ "$security" != "--" && "$security" != "" ]] && lock=" "

    if [ "$ssid" = "$current_ssid" ]; then
        entries+=("$icon  $ssid$lock  (connected)")
    else
        entries+=("$icon  $ssid$lock  ${signal}%")
    fi
    ssids+=("$ssid")
done < <(nmcli -t -f ssid,signal,security,active dev wifi list | sort -t: -k2 -nr | awk -F: '!seen[$1]++ {OFS="|"; print $1,$2,$3,$4}')

# Build wofi input
menu=""
for e in "${entries[@]}"; do
    menu+="$e\n"
done
menu+="  Turn Wi-Fi Off"

lines=$(( ${#entries[@]} + 1 ))
height=$(( lines * 36 + 20 ))
[ "$height" -gt 420 ] && height=420

chosen=$(printf "$menu" | wofi --dmenu --width 340 --height "$height" --cache-file /dev/null --prompt "Wi-Fi")
[ -z "$chosen" ] && exit 0

case "$chosen" in
    *"Turn Wi-Fi Off"*)
        nmcli radio wifi off
        notify-send -t 2000 "Wi-Fi" "Wi-Fi turned off"
        ;;
    *)
        # Find which SSID was selected
        for i in "${!entries[@]}"; do
            if [ "${entries[$i]}" = "$chosen" ]; then
                ssid="${ssids[$i]}"

                if [ "$ssid" = "$current_ssid" ]; then
                    # Already connected — disconnect
                    nmcli con down id "$ssid" 2>/dev/null
                    notify-send -t 2000 "Wi-Fi" "Disconnected from $ssid"
                else
                    # Check if we have a saved connection
                    if nmcli -t -f name con show | grep -qx "$ssid"; then
                        notify-send -t 2000 "Wi-Fi" "Connecting to $ssid..."
                        nmcli con up id "$ssid"
                    else
                        # New network — ask for password
                        password=$(wofi --dmenu --width 340 --height 55 --cache-file /dev/null --prompt "Password for $ssid" --password)
                        if [ -n "$password" ]; then
                            notify-send -t 2000 "Wi-Fi" "Connecting to $ssid..."
                            nmcli dev wifi connect "$ssid" password "$password"
                        fi
                    fi
                fi
                break
            fi
        done
        ;;
esac
